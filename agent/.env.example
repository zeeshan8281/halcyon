# --- LLM (via OpenRouter — one key, any model) ---
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Any model id OpenRouter supports.
#   anthropic/claude-sonnet-4.6  ← default
#   anthropic/claude-opus-4.7
#   openai/gpt-5
#   deepseek/deepseek-r1
#   meta-llama/llama-4-405b-instruct
MODEL=anthropic/claude-sonnet-4.6

# --- Hyperliquid (required — this is the hedge fund) ---
HL_NETWORK=testnet

# Generate the agent key (npm run gen-key). The agent address gets approved
# by the leader to trade on the leader's vault. Agent key cannot withdraw.
HL_AGENT_PRIVATE_KEY=

# The vault leader. The wallet that:
#   1. created the Hyperliquid vault
#   2. called approveAgent(<agent address>) on Hyperliquid
HL_LEADER_ADDRESS=

# The Hyperliquid vault the agent trades for.
HL_VAULT_ADDRESS=

# --- Agent ---
AGENT_NAME=Halcyon
LOOP_INTERVAL_SECONDS=60
MAX_POSITION_USD=200
MAX_TOTAL_EXPOSURE_USD=800
TRACKED_SYMBOLS=PENDLE,JTO,HYPE

# --- Twitter (optional) ---
TWITTER_DRY_RUN=true
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# --- Misc ---
LOG_DIR=./logs
PORT=8080
