# OpenRouter (one key, routes to Claude + others)
OPENROUTER_API_KEY=

# Discord bot (one bot account that listens to the channels below)
DISCORD_BOT_TOKEN=

# Internal/leadership channels — all personas route here.
# Comma-separated list of channel IDs. Add more channels by appending IDs.
# Example: 12345,67890,11111
DISCORD_LEADERSHIP_CHANNEL_IDS=
# Legacy: singular form, still read if set (treated as a single leadership channel).
DISCORD_CHANNEL_ID=

# Community channels — ONLY the community persona (Nico) responds here.
# Comma-separated. Same format as leadership.
DISCORD_COMMUNITY_CHANNEL_IDS=
# Legacy: singular form.
DISCORD_COMMUNITY_CHANNEL_ID=
COMMUNITY_PERSONA_ID=nico

# Webhook URLs — one per persona. Create 10 webhooks on your #halcyon-leadership channel.
# WEBHOOK_NICO should be created on your community channel instead.
WEBHOOK_MAYA=
WEBHOOK_PRIYA=
WEBHOOK_JORDAN=
WEBHOOK_THEO=
WEBHOOK_AMARA=
WEBHOOK_SAM=
WEBHOOK_WREN=
WEBHOOK_LENA=
WEBHOOK_ARJUN=
WEBHOOK_NICO=
WEBHOOK_DIEGO=

# Behavior
# CHIME_IN=true  -> on plain messages (no @mention), router picks 1-3 personas to respond
# CHIME_IN=false -> only respond to @mentions
CHIME_IN=true

# Models (OpenRouter IDs — swap as needed)
MODEL_PERSONA=anthropic/claude-sonnet-4.5
MODEL_ROUTER=anthropic/claude-haiku-4.5
