# OpenRouter (one key, routes to Claude + others)
OPENROUTER_API_KEY=

# Discord bot (one bot account that listens to the channel)
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# Webhook URLs — one per persona. Create 9 webhooks on your #halcyon-leadership channel.
WEBHOOK_MAYA=
WEBHOOK_PRIYA=
WEBHOOK_JORDAN=
WEBHOOK_THEO=
WEBHOOK_AMARA=
WEBHOOK_SAM=
WEBHOOK_WREN=
WEBHOOK_LENA=
WEBHOOK_DIEGO=

# Behavior
# CHIME_IN=true  -> on plain messages (no @mention), router picks 1-3 personas to respond
# CHIME_IN=false -> only respond to @mentions
CHIME_IN=true

# Models (OpenRouter IDs — swap as needed)
MODEL_PERSONA=anthropic/claude-sonnet-4.5
MODEL_ROUTER=anthropic/claude-haiku-4.5
